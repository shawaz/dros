# --- Convex (backend / database) ---------------------------------------------
# Created by running `npx convex dev` (it writes CONVEX_DEPLOYMENT and prints
# the URL). NEXT_PUBLIC_CONVEX_URL is read by the browser client.
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# --- Clerk (authentication) --------------------------------------------------
# From the Clerk dashboard → API keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Issuer domain of the "convex" JWT template you create in Clerk
# (Configure → JWT Templates → New → Convex). Set this in the CONVEX dashboard
# env vars too (Settings → Environment Variables), not just here.
CLERK_JWT_ISSUER_DOMAIN=

# Route Clerk to the in-app sign-in page and back to the dashboard after auth.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# --- Existing integrations (unchanged) ---------------------------------------
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=
# SENTINEL_HUB_CLIENT_ID=
# SENTINEL_HUB_CLIENT_SECRET=
# TURSO_DATABASE_URL=        # current Drizzle backend; removed after Convex migration completes
# TURSO_AUTH_TOKEN=
